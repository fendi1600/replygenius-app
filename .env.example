# ── Supabase ────────────────────────────────────────────────────────────────
# supabase.com → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON=your-anon-key-here

# ── Anthropic Claude API ─────────────────────────────────────────────────────
# console.anthropic.com → API Keys
EXPO_PUBLIC_CLAUDE_API_KEY=sk-ant-api03-...

# ── Meta (Facebook + Instagram) ──────────────────────────────────────────────
# developers.facebook.com → Your App → Settings → Basic
EXPO_PUBLIC_META_APP_ID=your-meta-app-id
EXPO_PUBLIC_META_APP_SECRET=your-meta-app-secret

# ── TikTok (MVP2) ────────────────────────────────────────────────────────────
# developers.tiktok.com → Manage Apps
EXPO_PUBLIC_TIKTOK_CLIENT_KEY=your-tiktok-client-key

# ── YouTube / Google (MVP2) ──────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
EXPO_PUBLIC_YOUTUBE_API_KEY=your-youtube-data-api-key
